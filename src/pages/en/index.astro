splay:grid;gap:12px}#modal-gallery img,#modal-gallery video{width:100%;display:block}#close-modal{float:right;font-size:30px;background:transparent;color:#fff;border:0}@media(max-width:700px){#menu{height:48px;padding:0 14px}.brand{font-size:14px}nav{display:none}.open nav{display:grid;position:absolute;top:48px;left:0;right:0;background:#252525;padding:12px 18px}.open nav a{padding:8px 0}.hero{height:360px}.hero h1{bottom:20px;font-size:50px}.areas{grid-template-columns:1fr;padding:20px 14px}.area-card{height:90px}.area-card.flipped{height:150px}.about{grid-template-columns:1fr;padding:35px 14px 0}.about img{margin-top:20px}.works,.experience{padding:30px 14px}.gallery{grid-template-columns:repeat(2,1fr)}.experience-list{grid-template-columns:1fr}footer{padding:30px 14px 18px}footer div{display:grid}}
