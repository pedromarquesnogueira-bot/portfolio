<style is:global>
  #gallery { display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); column-gap:12px; row-gap:16px; }
  #gallery .project { position:relative; display:block; box-sizing:border-box; width:100%; min-width:0; aspect-ratio:1; padding:0 !important; overflow:hidden; border:0 !important; border-radius:12px !important; appearance:none; background:#232323; color:#fff; line-height:0; cursor:pointer; }
  #gallery .project img { display:block; width:100%; height:100%; border:0 !important; border-radius:12px !important; outline:0; object-fit:cover; clip-path:inset(0 round 12px); }
  #gallery .project::after { content:""; position:absolute; right:0; bottom:0; left:0; height:55%; background:linear-gradient(to bottom, transparent, rgb(0 0 0 / .3)); opacity:0; pointer-events:none; transition:opacity .35s ease; }
  #gallery .project span { position:absolute !important; right:0 !important; bottom:6px !important; left:0 !important; z-index:1; display:block; padding:12px !important; background:transparent !important; color:#fff; font-weight:800; text-align:left; transform:translateY(120%); transition:transform .35s ease; }
  #gallery .project:hover::after, #gallery .project:focus-visible::after { opacity:1; }
  #gallery .project:hover span, #gallery .project:focus-visible span { transform:translateY(0); }
  @media(max-width:700px) { #gallery { grid-template-columns:repeat(2, minmax(0, 1fr)); column-gap:12px; row-gap:16px; } }
</style>
<style is:global>
  @media(min-width:701px) {
    #menu { padding-inline:60px !important; }
    main .areas, main .works, main .experience { padding-inline:60px !important; }
    main .about { padding-inline:60px !important; }
    body footer { padding-inline:60px !important; }
  }
  @media(min-width:701px) and (max-width:1200px) {
    main .areas { grid-template-columns:repeat(2, minmax(0, 1fr)) !important; }
    #gallery { grid-template-columns:repeat(3, minmax(0, 1fr)) !important; }
    main .about { min-height:690px !important; grid-template-columns:minmax(0, 1fr) minmax(0, 1fr) !important; }
    main .about > div:not(.about-portrait) { padding:82px 48px 60px 0 !important; }
    main .about > div:not(.about-portrait) p { max-width:410px !important; }
    main .about > .about-portrait { min-height:690px; }
    main .about > .about-portrait > img { width:100%; height:100%; object-fit:cover !important; object-position:right center !important; transform:none !important; }
  }
</style>
<style is:global>
  /* Mantém a seta dos títulos na mesma linha de base das letras, como nos cards. */
  main > section h2 i, body footer h2 i { width:20px; height:20px; margin-left:6px; vertical-align:baseline; position:relative; bottom:12px; }
  main > section h2 i { filter:brightness(0) invert(1); bottom:13px; }
  main > section h2 { position:relative; border-bottom:2px solid #a6a8aa !important; }
  main > section h2::after { content:""; position:absolute; right:0; bottom:-2px; width:5%; height:2px; background:#d9ff65; }
  body footer h2 { position:relative; border-bottom:2px solid #d8b6ff !important; }
  body footer h2::after { content:""; display:block !important; position:absolute; right:0; bottom:-2px; width:5%; height:2px; background:#d9ff65; }
</style>
<style is:global>
  main .areas .area-card, main .areas .area-card.flipped { height:500px !important; overflow:hidden; background:#232323 !important; transform:none !important; transition:background .4s ease !important; }
  main .areas { padding-top:75px !important; padding-bottom:75px !important; }
  main .areas .area-card span { position:absolute; top:16px; left:15px; z-index:3; display:flex; align-items:flex-end; gap:3px; color:#f5f2ef; line-height:1; transition:color .4s ease; }
  main .areas .area-card span i { display:block; align-self:flex-end; margin:0 0 8px; vertical-align:0; }
  main .areas .area-card strong { bottom:26px !important; z-index:2; display:block !important; opacity:1; transition:transform .4s ease, opacity .35s ease !important; }
  main .areas .area-card em { position:absolute; inset:0; z-index:1; display:flex !important; align-items:center; justify-content:center; padding:110px 24px 28px; background:#f7f5f2; color:#2a2a2a; font-style:normal; text-align:center; transform:translateY(100%); transition:transform .4s ease; pointer-events:none; }
  main .areas .area-card:hover strong, main .areas .area-card.flipped strong { transform:translateY(-150px); opacity:0; }
  main .areas .area-card:hover em, main .areas .area-card.flipped em { transform:translateY(0); }
  main .areas .area-card:hover span, main .areas .area-card.flipped span { color:#222222; }
  @media(max-width:700px) { main .areas { padding-top:40px !important; padding-bottom:40px !important; } main .areas .area-card, main .areas .area-card.flipped { height:350px !important; } main .areas .area-card em { padding-top:76px; } }
</style>
<style is:global>
  @media(max-width:700px) {
    #menu-toggle { display:flex !important; flex-direction:column; align-items:center; justify-content:center; gap:5px; position:absolute; right:14px; width:34px; height:34px; padding:0; border:0; background:transparent; cursor:pointer; }
    #menu-toggle span { display:block; width:20px; height:2px; border-radius:2px; background:#f5f2ef; }
    #menu nav { display:none; }
    #menu.open nav { display:grid !important; grid-template-columns:1fr; gap:4px; position:absolute; top:48px; right:0; left:0; height:auto; padding:12px 18px; background:#252525f2; border-bottom:1px solid #858585; }
  }
</style>
<style is:global>
  main .about { display:grid !important; grid-template-columns:1fr 1fr !important; align-items:stretch !important; min-height:440px; padding:0 0 0 2.2vw !important; background:#2d2d2d !important; }
  main .about > div:not(.about-portrait) { padding:55px 60px 55px 0; }
  main .about > .about-portrait { padding:0 !important; overflow:hidden !important; }
  main .about > .about-portrait > img { display:block; width:100%; height:100%; max-height:none !important; object-fit:contain !important; object-position:right bottom !important; }
  main .about p { width:100%; max-width:none !important; margin:0 0 24px; }
  @media(min-width:701px) { main .about { padding-left:60px !important; } main .about > .about-portrait > img { transform:translate(-12%, -10%) scale(1.72) !important; transform-origin:74% 38% !important; } }
  @media(max-width:700px) { main .about { grid-template-columns:1fr !important; padding:0 !important; } main .about > div:not(.about-portrait) { padding:35px 14px 20px; } main .about > .about-portrait > img { height:auto; object-position:right bottom !important; } }
</style>
<style is:global>
  main .experience article { display:grid !important; grid-template-columns:minmax(0, .85fr) minmax(0, 1.15fr); align-items:start; column-gap:42px; padding:34px 38px !important; }
  main .experience { padding-bottom:100px !important; }
  main .experience .experience-period { display:block; color:#f5f2ef; font-weight:800 !important; text-align:right; line-height:1.25; }
  main .experience .experience-content { min-width:0; text-align:left; }
  main .experience .experience-content strong, main .experience .experience-content b, main .experience .experience-content p { text-align:left; }
  main .experience .experience-content b { margin-top:7px; }
  main .experience .experience-content p { margin:24px 0 0; }
  @media(max-width:700px) { main .experience { padding-bottom:60px !important; } main .experience article { grid-template-columns:1fr; row-gap:12px; padding:24px !important; } main .experience .experience-period { text-align:left; } }
</style>
<style is:global>
  /* Tablet: mantém o retrato preenchendo a coluna direita, sem herdar o recorte do desktop. */
  @media(min-width:701px) and (max-width:1200px) {
    main .about.about > .about-portrait > img { object-fit:cover !important; object-position:70% center !important; transform:none !important; }
    main .experience .experience-list { grid-template-columns:repeat(2, minmax(0, 1fr)) !important; }
    main .experience article { grid-template-columns:1fr !important; row-gap:12px; padding:24px !important; }
    main .experience .experience-period { text-align:left !important; }
  }
</style>

<style is:global>
  main .filters label { padding:4px 25px 4px 9px !important; }
  main .filters label span { color:#2a2a2a !important; font-size:20px; font-weight:800; line-height:1; opacity:1; }
  main .filters #search { width:220px; }
</style>
