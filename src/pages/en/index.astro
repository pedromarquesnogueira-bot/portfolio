import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

const fixedFilters = [["Todos", "All"], ["Design Digital", "Digital Design"], ["Direção de Arte", "Art Direction"], ["Design Editorial", "Editorial Design"], ["Comunicação Corporativa", "Corporate Communication"]] as const;
const areas = [["01", "Digital Design", "Websites|Landing pages|Social media|Email marketing"], ["02", "Art Direction", "Visual concepts|Campaigns|Advertisements|Key visuals"], ["03", "Editorial Design", "Catalogues|Magazines|E-books|Reports|Presentations"], ["04", "Corporate Communication", "Internal communication|Institutional materials|Events|Internal marketing"]];
const [{ data: settings }, { data: projects }, { data: images }, { data: projectTags }, { data: tags }, { data: projectTools }, { data: tools }, { data: experiences }] = await Promise.all([
  supabase.from("site_settings").select("*").eq("id", true).maybeSingle(), supabase.from("projects").select("*").eq("published", true).order("sort_order").order("created_at"), supabase.from("project_images").select("*").order("sort_order"), supabase.from("project_tags").select("*"), supabase.from("tags").select("*"), supabase.from("project_tools").select("*"), supabase.from("tools").select("id,name,icon_url"), supabase.from("experiences").select("*").eq("published", true).order("sort_order"),
]);
const tagNames = new Map((tags ?? []).map((tag) => [tag.id, { pt: tag.name, en: tag.name_en || tag.name }]));
const toolData = new Map((tools ?? []).map((tool) => [tool.id, { name: tool.name, iconUrl: tool.icon_url }]));
const aboutText = settings?.about_en || settings?.about_pt || "Creative professional with over 20 years of experience across print and digital communication.";
const aboutParagraphs = aboutText.split(/\r?\n\s*\r?\n/).filter(Boolean);
const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
const formatExperienceMonth = (value: string | null | undefined) => {
  if (!value) return "";
  const match = value.match(/^(\d{4})-(\d{2})/);
  if (!match) return value;
  return `${monthNames[Number(match[2]) - 1]}.${match[1]}`;
};
const projectData = (projects ?? []).map((project) => {
  const media = (images ?? []).filter((image) => image.project_id === project.id).map((image) => image.image_url);
  const projectTagsData = (projectTags ?? []).filter((item) => item.project_id === project.id).map((item) => tagNames.get(item.tag_id)).filter((tag): tag is { pt: string; en: string } => Boolean(tag));
  return { ...project, title: project.title_en || project.title, description: project.description_en || project.description, image: project.cover_image ?? media[0], media, tags: projectTagsData.map((tag) => tag.en), tagKeys: projectTagsData.map((tag) => tag.pt), tools: (projectTools ?? []).filter((item) => item.project_id === project.id).map((item) => toolData.get(item.tool_id)).filter(Boolean) };
});
---
<BaseLayout title={settings?.seo_title_en || settings?.seo_title_pt || "Pedro MRKZ · Portfolio"} analyticsId="G-QSEVKF5DBS" lang="en">
  <header id="menu"><a class="brand" href="#home">PEDRO<span>.MRKZ</span></a><nav><a href="#home">Home</a><a href="#trabalhos">Work</a><a href="#experiencia">Experience</a><a href="#contato">Contact</a></nav><div class="language-switch" aria-label="Language"><a href="/">PT</a><span aria-current="page">EN</span></div><button id="menu-toggle" aria-label="Open menu"><span></span><span></span><span></span></button></header>
  <main>
    <section id="home" class="hero" style={`background-image:url('${settings?.hero_banner_url || "/images/hero.png"}')`}><h1>PORTFOLIO <span>CREATIVE</span></h1></section>
    <section class="areas" aria-label="Areas of expertise">{areas.map(([number, title, detail]) => <button class="area-card"><span>{number}<i>↙</i></span><strong>{title}</strong><em>{detail.split("|").map((line) => <Fragment>{line}<br /></Fragment>)}</em></button>)}</section>
    <section class="about"><div><h2>ABOUT ME <i>↙</i></h2>{aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}</div><div class="about-portrait"><img src="/images/bg-aboutme.png" alt="Portrait of Pedro Marques" /></div></section>
    <section id="trabalhos" class="works"><h2>WORK <i>↙</i></h2><div class="filters">{fixedFilters.map(([filter, label], index) => <button class:list={{ active: index === 0 }} data-filter={filter}>{label}</button>)}<label><input id="search" placeholder="What are you looking for?" /><span>⌕</span></label></div><div id="gallery" class="gallery"></div></section>
    <section id="experiencia" class="experience"><h2>EXPERIENCE <i>↙</i></h2><div class="experience-list">{(experiences ?? []).map((item) => <article><small class="experience-period">{item.current_job ? `${formatExperienceMonth(item.start_date)} - Present` : `${formatExperienceMonth(item.start_date)} - ${formatExperienceMonth(item.end_date)}`}</small><div class="experience-content"><strong>{item.company}</strong><b>{item.position_en || item.position}</b><p>{item.description_en || item.description}</p></div></article>)}</div></section>
  </main>
  <footer id="contato"><h2>CONTACT <i>↙</i></h2><div>{settings?.whatsapp && <a href={`https://wa.me/${settings.whatsapp.replace(/\D/g, "")}`} target="_blank"><img src="/images/contact/whatsapp.png" alt="">{settings.whatsapp}</a>}{settings?.email && <a href={`mailto:${settings.email}`}><img src="/images/contact/email.png" alt="">{settings.email}</a>}{settings?.linkedin && <a href={settings.linkedin} target="_blank"><img src="/images/contact/linkedin.png" alt="">LinkedIn</a>}{settings?.behance && <a href={settings.behance} target="_blank"><img src="/images/contact/behance.png" alt="">Behance</a>}</div><small>Pedro Marques · Art Director · © 2026</small></footer>
  <dialog id="project-modal"><div class="modal-shell"><header><h2 id="modal-title"></h2><button id="close-modal" aria-label="Close">×</button></header><div id="modal-gallery"></div><section id="modal-details"></section></div></dialog>
</BaseLayout>
<script define:vars={{ projectData }}>
  const projects = projectData; let filter = "Todos", query = "";
  const gallery = document.querySelector("#gallery"); const modal = document.querySelector("#project-modal");
  const render = () => { const match = projects.filter(p => (filter === "Todos" || p.tagKeys.includes(filter)) && `${p.title} ${p.client || ""} ${p.description || ""} ${p.tags.join(" ")}`.toLowerCase().includes(query.toLowerCase())); if (gallery) gallery.innerHTML = match.map(p => `<button class="project" data-id="${p.id}">${p.image ? `<img src="${p.image}" alt="${p.title}">` : ""}<span>${p.title}</span></button>`).join("") || "<p>No work found.</p>"; };
  document.querySelectorAll("[data-filter]").forEach(button => button.addEventListener("click", () => { filter=button.dataset.filter || "Todos"; document.querySelectorAll("[data-filter]").forEach(x=>x.classList.toggle("active",x===button)); render(); }));
  document.querySelector("#search")?.addEventListener("input", event => { query=event.target.value; render(); });
  const projectKey = project => project.slug || project.id;
  const openProject = project => { if(!project||!modal)return; document.querySelector("#modal-title").textContent=project.title; const media=project.media; const asset=url => /\.(mp4|webm|mov)(\?|$)/i.test(url) ? `<video controls src="${url}"></video>` : `<img src="${url}" alt="${project.title}">`; document.querySelector("#modal-gallery").innerHTML=media.length ? media.map(asset).join("") : `<p class="empty-modal-gallery">This project does not yet have gallery images.</p>`; document.querySelector("#modal-details").innerHTML=`<div><h3>Description</h3><p>${project.description || "—"}</p></div><div><h3>Client</h3><p>${project.client || "—"}</p></div><div><h3>Keywords</h3><div class="modal-tags">${project.tags.map(tag=>`<span>${tag}</span>`).join("") || "—"}</div></div><div><h3>Tools used</h3><div class="modal-tools">${project.tools.map(tool=>`<div>${tool.iconUrl ? `<img src="${tool.iconUrl}" alt="">` : ""}<span>${tool.name}</span></div>`).join("") || "—"}</div></div>`; if (!modal.open) modal.showModal(); if (typeof window.gtag === "function") window.gtag("event", "view_project", { project_id: project.id, project_title: project.title, project_slug: projectKey(project), language: "en" }); };
  gallery?.addEventListener("click", event => { const id=event.target.closest("[data-id]")?.dataset.id; const project=projects.find(item=>item.id===id); if(!project)return; history.pushState({}, "", `/en/project/${encodeURIComponent(projectKey(project))}`); openProject(project); });
  const clearProjectUrl = () => { if (location.pathname.startsWith("/en/project/")) history.replaceState({}, "", "/en/"); };
  document.querySelector("#close-modal")?.addEventListener("click",()=>modal?.close()); modal?.addEventListener("click",e=>{if(e.target===modal)modal.close()}); modal?.addEventListener("close",clearProjectUrl);
  let lastY = scrollY;
  let smoothScrolling = false;
  const menu = document.querySelector("#menu");
  addEventListener("scroll", () => {
    if (!smoothScrolling) menu?.classList.toggle("hidden", scrollY > lastY && scrollY > 90);
    lastY = scrollY;
  }, { passive: true });
  addEventListener("mousemove", (event) => { if (event.clientY <= 90) menu?.classList.remove("hidden"); }, { passive: true });
  document.querySelector("#menu-toggle")?.addEventListener("click", () => menu?.classList.toggle("open"));
  menu?.querySelector("nav")?.addEventListener("click", () => menu?.classList.remove("open"));
  const scrollToSection = hash => {
    const target = document.querySelector(hash);
    if (!target) return;
    const start = window.scrollY;
    const menuHeight = menu?.getBoundingClientRect().height || 0;
    const destination = Math.max(0, target.getBoundingClientRect().top + start - menuHeight);
    const distance = destination - start;
    if (Math.abs(distance) < 2) return;
    const duration = Math.min(1300, Math.max(550, Math.abs(distance) * .45));
    const startedAt = performance.now();
    const easeOutQuart = progress => 1 - Math.pow(1 - progress, 4);
    smoothScrolling = true;
    menu?.classList.remove("hidden");
    const animate = now => {
      const progress = Math.min(1, (now - startedAt) / duration);
      window.scrollTo(0, start + distance * easeOutQuart(progress));
      if (progress < 1) requestAnimationFrame(animate);
      else {
        window.scrollTo(0, destination);
        smoothScrolling = false;
        lastY = destination;
      }
    };
    requestAnimationFrame(animate);
  };
  menu?.querySelectorAll('a[href^="#"]').forEach(link => link.addEventListener("click", event => {
    const hash = link.getAttribute("href");
    if (!hash || !document.querySelector(hash)) return;
    event.preventDefault();
    menu?.classList.remove("open");
    history.pushState(null, "", hash);
    scrollToSection(hash);
  }));
  render(); const sharedProject = new URLSearchParams(location.search).get("projeto"); const sharedItem = projects.find(project => projectKey(project) === sharedProject); if (sharedItem) { history.replaceState({}, "", `/en/project/${encodeURIComponent(projectKey(sharedItem))}`); openProject(sharedItem); }
</script>
