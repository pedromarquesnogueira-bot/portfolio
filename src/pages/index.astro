---
import BaseLayout from "@layouts/BaseLayout.astro";
import { supabase } from "@lib/supabase";

const fixedFilters = ["Todos", "Design Digital", "Direção de Arte", "Design Editorial", "Comunicação Corporativa"];
const areas = [["01", "Design Digital", "Sites|Landing pages|Mídias sociais|E-mail marketing"], ["02", "Direção de Arte", "Conceitos visuais|Campanhas|Key visuals"], ["03", "Design Editorial", "Catálogos|Revistas|E-books|Relatórios|Apresentações"], ["04", "Comunicação Corporativa", "Comunicação interna|Campanhas|Materiais institucionais|Eventos|Endomarketing"]];
const [{ data: settings }, { data: projects }, { data: images }, { data: projectTags }, { data: tags }, { data: projectTools }, { data: tools }, { data: experiences }] = await Promise.all([
  supabase.from("site_settings").select("*").eq("id", true).maybeSingle(), supabase.from("projects").select("*").eq("published", true).order("sort_order"), supabase.from("project_images").select("*").order("sort_order"), supabase.from("project_tags").select("*"), supabase.from("tags").select("*"), supabase.from("project_tools").select("*"), supabase.from("tools").select("id,name,icon_url"), supabase.from("experiences").select("*").eq("published", true).order("sort_order"),
]);
const tagNames = new Map((tags ?? []).map((tag) => [tag.id, tag.name]));
const toolData = new Map((tools ?? []).map((tool) => [tool.id, { name: tool.name, iconUrl: tool.icon_url }]));
const aboutText = settings?.about_pt || "Formado em Publicidade e Propaganda, atuo há mais de 20 anos em diversas frentes da comunicação, do impresso ao digital.";
const aboutParagraphs = aboutText.split(/\r?\n\s*\r?\n/).filter(Boolean);
const projectData = (projects ?? []).map((project) => {
  const media = (images ?? []).filter((image) => image.project_id === project.id).map((image) => image.image_url);
  return { ...project, image: project.cover_image ?? media[0], media, tags: (projectTags ?? []).filter((item) => item.project_id === project.id).map((item) => tagNames.get(item.tag_id)).filter(Boolean), tools: (projectTools ?? []).filter((item) => item.project_id === project.id).map((item) => toolData.get(item.tool_id)).filter(Boolean) };
});
---
<BaseLayout title={settings?.seo_title_pt || "Pedro Marques · Portfólio"}>
  <header id="menu"><a class="brand" href="#home">PEDRO<span>.MARQUES</span></a><nav><a href="#home">Home</a><a href="#trabalhos">Trabalhos</a><a href="#experiencia">Experiência</a><a href="#contato">Contato</a></nav><button id="menu-toggle" aria-label="Abrir menu">☰</button></header>
  <main>
    <section id="home" class="hero" style={`background-image:url('${settings?.hero_banner_url || "/images/hero.png"}')`}><h1>PORTFOLIO <span>CRIATIVO</span></h1></section>
    <section class="areas" aria-label="Áreas de atuação">{areas.map(([number, title, detail]) => <button class="area-card"><span>{number}<i>↙</i></span><strong>{title}</strong><em>{detail.split("|").map((line) => <Fragment>{line}<br /></Fragment>)}</em></button>)}</section>
    <section class="about"><div><h2>SOBRE MIM <i>↙</i></h2>{aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}</div><img src="/images/sobre-mim.png" alt="Retrato de Pedro Marques" /></section>
    <section id="trabalhos" class="works"><h2>TRABALHOS <i>↙</i></h2><div class="filters">{fixedFilters.map((filter, index) => <button class:list={{ active: index === 0 }} data-filter={filter}>{filter}</button>)}<label><input id="search" placeholder="O que quer ver?" /><span>⌕</span></label></div><div id="gallery" class="gallery"></div><button id="load-more" class="outline">Carregar mais</button></section>
    <section id="experiencia" class="experience"><h2>EXPERIÊNCIA <i>↙</i></h2><div class="experience-list">{(experiences ?? []).map((item) => <article><strong>{item.company}</strong><b>{item.position}</b><small>{item.current_job ? `${item.start_date} · Atual` : `${item.start_date} · ${item.end_date}`}</small><p>{item.description}</p></article>)}</div></section>
  </main>
  <footer id="contato"><h2>CONTATO <i>↙</i></h2><div>{settings?.whatsapp && <a href={`https://wa.me/${settings.whatsapp.replace(/\D/g, "")}`} target="_blank">◉ {settings.whatsapp}</a>}{settings?.email && <a href={`mailto:${settings.email}`}>✉ {settings.email}</a>}{settings?.linkedin && <a href={settings.linkedin} target="_blank">in LinkedIn</a>}{settings?.behance && <a href={settings.behance} target="_blank">Be Behance</a>}</div><small>Pedro Marques · Diretor de Arte · © 2026</small></footer>
  <dialog id="project-modal"><div class="modal-shell"><header><h2 id="modal-title"></h2><button id="close-modal" aria-label="Fechar">×</button></header><div id="modal-gallery"></div><section id="modal-details"></section></div></dialog>
</BaseLayout>
<script define:vars={{ projectData }}>
  const projects = projectData; let filter = "Todos", query = "", limit = 10;
  const gallery = document.querySelector("#gallery"); const more = document.querySelector("#load-more"); const modal = document.querySelector("#project-modal");
  const render = () => { const match = projects.filter(p => (filter === "Todos" || p.tags.includes(filter)) && `${p.title} ${p.client || ""} ${p.description || ""} ${p.tags.join(" ")}`.toLowerCase().includes(query.toLowerCase())); const shown = filter === "Todos" && !query ? match.slice(0,limit) : match; if (gallery) gallery.innerHTML = shown.map(p => `<button class="project" data-id="${p.id}">${p.image ? `<img src="${p.image}" alt="${p.title}">` : ""}<span>${p.title}</span></button>`).join("") || "<p>Nenhum trabalho encontrado.</p>"; if(more) more.hidden = !(filter === "Todos" && !query && limit < match.length); };
  document.querySelectorAll("[data-filter]").forEach(button => button.addEventListener("click", () => { filter=button.dataset.filter || "Todos"; limit=10; document.querySelectorAll("[data-filter]").forEach(x=>x.classList.toggle("active",x===button)); render(); }));
  document.querySelector("#search")?.addEventListener("input", event => { query=event.target.value; render(); }); more?.addEventListener("click",()=>{limit+=10;render()});
  gallery?.addEventListener("click", event => { const id=event.target.closest("[data-id]")?.dataset.id; const project=projects.find(item=>item.id===id); if(!project||!modal)return; document.querySelector("#modal-title").textContent=project.title; const media=project.media; const asset=url => /\.(mp4|webm|mov)(\?|$)/i.test(url) ? `<video controls src="${url}"></video>` : `<img src="${url}" alt="${project.title}">`; document.querySelector("#modal-gallery").innerHTML=media.length ? media.map(asset).join("") : `<p class="empty-modal-gallery">Este projeto ainda não possui imagens de galeria.</p>`; document.querySelector("#modal-details").innerHTML=`<div><h3>Descrição</h3><p>${project.description || "—"}</p></div><div><h3>Cliente</h3><p>${project.client || "—"}</p></div><div><h3>Palavras-chave</h3><div class="modal-tags">${project.tags.map(tag=>`<span>${tag}</span>`).join("") || "—"}</div></div><div><h3>Ferramentas utilizadas</h3><div class="modal-tools">${project.tools.map(tool=>`<div>${tool.iconUrl ? `<img src="${tool.iconUrl}" alt="">` : ""}<span>${tool.name}</span></div>`).join("") || "—"}</div></div>`; modal.showModal(); });
  document.querySelector("#close-modal")?.addEventListener("click",()=>modal?.close()); modal?.addEventListener("click",e=>{if(e.target===modal)modal.close()});
  document.querySelectorAll(".area-card").forEach(card=>card.addEventListener("click",()=>card.classList.toggle("flipped"))); let lastY=scrollY; const menu=document.querySelector("#menu"); addEventListener("scroll",()=>{menu?.classList.toggle("hidden",scrollY>lastY&&scrollY>90);lastY=scrollY},{passive:true}); document.querySelector("#menu-toggle")?.addEventListener("click",()=>menu?.classList.toggle("open")); render();
</script>
<style>
  :global(body){background:#232323;color:#f5f2ef;font-family:Arial,sans-serif}#menu,.hero h1,h2,.area-card,.brand,nav,.filters,.outline,.experience strong,.experience b,footer{font-family:"Barlow",sans-serif}#menu{height:62px;position:fixed;inset:0 0 auto;z-index:3;display:flex;align-items:center;justify-content:space-between;padding:0 2.2vw;background:#28252ddd;backdrop-filter:blur(7px);transition:transform .35s}.hidden{transform:translateY(-100%)}.brand{font-weight:900;color:#fff;text-decoration:none;font-size:22px}.brand span,h2{color:#e0ed65}nav{display:flex;gap:25px}nav a{color:#fff;text-decoration:none;font-size:11px;text-transform:uppercase;border-bottom:2px solid transparent;padding:23px 0 5px}nav a:hover{color:#e0ed65;border-color:#e0ed65}#menu-toggle{display:none}.hero{height:650px;background-size:cover;background-position:center;position:relative}.hero h1{position:absolute;left:2.2vw;bottom:82px;margin:0;font-size:clamp(62px,10.5vw,160px);line-height:.82;font-weight:900}.hero h1 span{display:block;color:#e0ed65;font-size:.62em}.areas,.about,.works,.experience{padding:55px 2.2vw}.areas{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.area-card{height:180px;border:1px solid #646464;border-radius:12px;background:#232323;color:#fff;text-align:left;padding:15px;position:relative;cursor:pointer;transition:.5s;transform-style:preserve-3d}.area-card.flipped{transform:rotateY(180deg);background:#f7f5f2;color:#2a2a2a}.area-card span{font-size:34px;font-weight:900;line-height:1}.area-card strong{position:absolute;bottom:20px;left:15px;font-size:20px}.area-card em{display:none}.area-card.flipped strong{display:none}.area-card.flipped em{display:block;transform:rotateY(180deg);font-style:normal;text-align:center;font-size:10px;line-height:1.6}.about{display:grid;grid-template-columns:1fr 1.2fr;align-items:end;background:#2d2d2d}.about p{font-size:12px;line-height:1.5;max-width:530px}.about img{width:100%;max-height:310px;object-fit:cover;object-position:center 25%}h2{font-size:24px;border-bottom:2px solid #78802e;padding-bottom:10px;line-height:1}h2 i,.area-card i{display:inline-block;width:13px;height:13px;margin-left:4px;background:url('/images/seta.svg') center/contain no-repeat;font-size:0;vertical-align:-1px}.area-card i{width:16px;height:16px;margin-left:2px;vertical-align:-2px}.filters{display:flex;justify-content:center;gap:8px;flex-wrap:wrap}.filters button,.outline{border:1px solid #777;background:#232323;color:#fff;border-radius:5px;padding:5px 12px;font-size:10px;cursor:pointer}.filters button:hover,.filters button.active,.outline:hover{background:#e0ed65;color:#171717}.filters label{background:#fff;border-radius:5px;padding:2px 8px}.filters input{border:0;outline:0;font-size:10px}.gallery{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin:34px 0}.project{aspect-ratio:1;border:0;border-radius:10px;overflow:hidden;background:#352b2a;color:#fff;position:relative}.project img{width:100%;height:100%;object-fit:cover}.project span{position:absolute;inset:auto 0 0;padding:12px;text-align:left;background:#0008;font-weight:bold}.outline{display:block;margin:auto;width:150px}.experience-list{display:grid;grid-template-columns:repeat(2,1fr);gap:12px}.experience article{background:#383838;border-radius:12px;padding:22px;min-height:150px;transition:.2s}.experience article:hover{background:#5a5a5a}.experience strong,.experience b,.experience small{display:block}.experience strong{color:#e0ed65}.experience small,.experience p{font-size:11px}footer{background:#9845ff;padding:48px 2.2vw 20px}footer h2{color:#fff;border-color:#d8b6ff}footer div{display:flex;justify-content:space-between;gap:15px;flex-wrap:wrap}footer a,footer small{color:#fff;text-decoration:none;font-size:13px}footer small{display:block;text-align:center;margin-top:55px;font-size:9px}dialog{max-width:min(900px,94vw);border:0;background:#242424;color:#fff;padding:28px}dialog::backdrop{background:#000b;backdrop-filter:blur(5px)}#modal-gallery{display:grid;gap:12px}#modal-gallery img,#modal-gallery video{width:100%;display:block}#close-modal{float:right;font-size:30px;background:transparent;color:#fff;border:0}@media(max-width:700px){#menu{height:48px;padding:0 14px}.brand{font-size:14px}nav{display:none}.open nav{display:grid;position:absolute;top:48px;left:0;right:0;background:#252525;padding:12px 18px}.open nav a{padding:8px 0}.hero{height:360px}.hero h1{bottom:20px;font-size:50px}.areas{grid-template-columns:1fr;padding:20px 14px}.area-card{height:90px}.area-card.flipped{height:150px}.about{grid-template-columns:1fr;padding:35px 14px 0}.about img{margin-top:20px}.works,.experience{padding:30px 14px}.gallery{grid-template-columns:repeat(2,1fr)}.experience-list{grid-template-columns:1fr}footer{padding:30px 14px 18px}footer div{display:grid}}
</style>
<style is:global>
  body { font-family:"Geist", Arial, sans-serif; }
  #menu, .brand, nav { font-family:"Barlow", sans-serif; }
  nav a { font-size:14px; }
  .hero h1 { font-family:"Barlow Condensed", sans-serif; }
  main > section h2, footer h2 { font-family:"Barlow Condensed", sans-serif; font-size:40px; }
  .area-card { font-family:"Barlow Condensed", sans-serif; }
  .area-card span { font-size:72px; }
  .area-card strong { font-size:40px; line-height:.9; }
  .area-card em { font-family:"Geist", Arial, sans-serif; font-size:16px; line-height:1.35; }
  .about p { font-size:16px; }
  .filters button, .filters input, .outline { font-size:16px; }
  .filters label { padding:4px 9px; }
  .outline { width:auto; min-width:170px; }
  .experience article { min-height:210px; }
  .experience strong, .experience b, .experience small, .experience p { font-family:"Geist", Arial, sans-serif; font-size:16px; }
  .experience strong { font-weight:800; }
  .experience b { font-weight:400; }
  footer a { font-size:16px; }
  footer small { font-size:14px; }
  @media(max-width:700px) { .area-card, .area-card.flipped { height:230px; } .area-card strong { bottom:18px; } }
</style>
<style>
  #project-modal { width:80vw; max-width:1560px; max-height:92vh; margin:auto; padding:0; border:0; border-radius:0 0 8px 8px; background:transparent; color:#292929; overflow:auto; }
  #project-modal::backdrop { background:rgb(0 0 0 / .76); backdrop-filter:blur(7px); }
  .modal-shell > header { display:flex; align-items:center; justify-content:space-between; padding:28px 0 34px; background:transparent; color:#b000ff; }
  .modal-shell > header h2 { margin:0; padding:0; border:0; color:#b000ff; font-size:35px; text-transform:none; }
  #close-modal { display:grid; place-items:center; width:30px; height:30px; border:0; border-radius:50%; background:#050505; color:#fff; font-size:30px; line-height:1; cursor:pointer; }
  #modal-gallery { display:flex; flex-direction:column; gap:0; background:transparent; margin:0; padding:0; border:0; font-size:0; line-height:0; }
  #modal-gallery :global(img), #modal-gallery :global(video) { display:block; flex:0 0 auto; width:100%; height:auto; margin:0 !important; padding:0 !important; border:0; object-fit:contain; vertical-align:top; }
  #modal-gallery :global(.empty-modal-gallery) { margin:0; padding:48px 24px; background:#f8f8f8; color:#555; font-size:16px; line-height:1.4; text-align:center; }
  #modal-details { display:grid; grid-template-columns:1.3fr .9fr 1.3fr 1.35fr; gap:28px; padding:30px; background:#f8f8f8; min-height:200px; }
  #modal-details :global(h3) { margin:0 0 13px; color:#a6a8aa; font:800 16px "Barlow",sans-serif; text-transform:uppercase; }
  #modal-details :global(p) { margin:0; color:#222; font-size:16px; line-height:1.25; }
  :global(.modal-tags) { display:flex; flex-wrap:wrap; gap:10px; }
  :global(.modal-tags span) { box-sizing:border-box; display:inline-flex; align-items:center; height:32px; border:1px solid #a6a8aa; border-radius:8px; padding:0 14px; color:#222; font-size:16px; }
  :global(.modal-tools) { display:grid; gap:8px; }
  :global(.modal-tools > div) { box-sizing:border-box; display:flex; align-items:center; gap:8px; height:40px; padding:5px; border:1px solid #a6a8aa; border-radius:8px; background:#fff; color:#222; font-size:16px; }
  :global(.modal-tools img) { width:28px; height:28px; object-fit:contain; }
  @media(max-width:700px) { #project-modal { width:94vw; } .modal-shell > header { padding:18px 14px; } .modal-shell > header h2 { font-size:26px; } #modal-details { grid-template-columns:1fr; gap:20px; padding:22px 16px; } }
</style>
<style is:global>
  #menu nav a { font-size:14px !important; }
  main .hero h1 { font-family:"Barlow Condensed", sans-serif !important; }
  main > section h2, body footer h2 { font-family:"Barlow Condensed", sans-serif !important; font-size:40px !important; }
  main .area-card { font-family:"Barlow Condensed", sans-serif !important; }
  main .area-card span { font-size:72px !important; }
  main .area-card strong { font-size:40px !important; line-height:.9 !important; }
  main .area-card em { font-family:"Geist", Arial, sans-serif !important; font-size:16px !important; line-height:1.35 !important; }
  main .about p { font-size:16px !important; }
  main .filters button, main .filters input, main .outline { font-size:16px !important; }
  main .filters label { padding:4px 9px !important; }
  main .outline { width:auto !important; min-width:170px !important; }
  main .experience article { min-height:210px !important; }
  main .experience strong, main .experience b, main .experience small, main .experience p { font-family:"Geist", Arial, sans-serif !important; font-size:16px !important; }
  main .experience strong { font-weight:800 !important; }
  main .experience b { font-weight:400 !important; }
  body footer a { font-size:16px !important; }
  body footer small { font-size:14px !important; }
  @media(max-width:700px) { main .area-card, main .area-card.flipped { height:230px !important; } main .area-card strong { bottom:18px !important; } }
</style>
<style is:global>
  #menu nav { height:100%; align-items:center; }
  #menu nav a { position:relative; display:flex; align-items:center; height:100%; padding:0; border-bottom:0; }
  #menu { border-bottom:1px solid #858585; }
  #menu nav a::after { content:""; position:absolute; right:0; bottom:18px; left:0; height:2px; background:#e0ed65; transform:scaleX(0); transform-origin:left center; transition:transform .28s ease-out; }
  #menu nav a:hover, #menu nav a:focus-visible { color:#e0ed65; }
  #menu nav a:hover::after, #menu nav a:focus-visible::after { transform:scaleX(1); }
  @media(max-width:700px) { #menu.open nav a { height:auto; padding:8px 0; } #menu.open nav a::after { bottom:3px; } }
</style>
<style is:global>
  @media(min-width:701px) {
    #menu { padding-inline:60px !important; }
    main .areas, main .works, main .experience { padding-inline:60px !important; }
    main .about { padding-inline:60px !important; }
    body footer { padding-inline:60px !important; }
  }
</style>
<style is:global>
  /* Mantém a seta dos títulos na mesma linha de base das letras, como nos cards. */
  main > section h2 i, body footer h2 i { width:20px; height:20px; margin-left:6px; vertical-align:baseline; position:relative; bottom:12px; }
  main > section h2, body footer h2 { position:relative; border-bottom:2px solid #858585; }
  main > section h2::after, body footer h2::after { content:""; position:absolute; right:0; bottom:-2px; width:10%; height:2px; background:#d9ff65; }
</style>
<style is:global>
  main .areas .area-card, main .areas .area-card.flipped { height:500px !important; overflow:hidden; background:#232323 !important; transform:none !important; transition:background .4s ease !important; }
  main .areas .area-card span { position:absolute; top:16px; left:15px; z-index:3; display:flex; align-items:flex-end; gap:3px; color:#f5f2ef; line-height:1; transition:color .4s ease; }
  main .areas .area-card span i { display:block; align-self:flex-end; margin:0 0 8px; vertical-align:0; }
  main .areas .area-card strong { bottom:26px !important; z-index:2; display:block !important; opacity:1; transition:transform .4s ease, opacity .35s ease !important; }
  main .areas .area-card em { position:absolute; inset:0; z-index:1; display:flex !important; align-items:center; justify-content:center; padding:110px 24px 28px; background:#f7f5f2; color:#2a2a2a; font-style:normal; text-align:center; transform:translateY(100%); transition:transform .4s ease; pointer-events:none; }
  main .areas .area-card:hover strong, main .areas .area-card.flipped strong { transform:translateY(-150px); opacity:0; }
  main .areas .area-card:hover em, main .areas .area-card.flipped em { transform:translateY(0); }
  main .areas .area-card:hover span, main .areas .area-card.flipped span { color:#222222; }
  @media(max-width:700px) { main .areas .area-card, main .areas .area-card.flipped { height:500px !important; } }
</style>
<style is:global>
  main .about { display:grid !important; grid-template-columns:1fr 1fr !important; align-items:stretch !important; min-height:440px; padding:0 2.2vw !important; background:#2d2d2d !important; }
  main .about > div { padding:55px 2.2vw 55px 0; }
  main .about > img { display:block; width:100%; height:100%; max-height:none !important; object-fit:cover !important; object-position:center top !important; }
  main .about p { width:100%; max-width:none !important; margin:0 0 24px; }
  @media(max-width:700px) { main .about { grid-template-columns:1fr !important; padding:0 14px !important; } main .about > div { padding:35px 0 20px; } main .about > img { height:420px; object-position:center top !important; } }
</style>
