---
import CMSLayout from "@layouts/CMSLayout.astro";
---

<CMSLayout>
  <section class="analytics-page">
    <h1>ANALYTICS</h1>
    <p>Acompanhe as visitas e o desempenho do site no Google Analytics.</p>
    <a href="https://analytics.google.com/analytics/web/" target="_blank" rel="noreferrer">Abrir Google Analytics</a>
  </section>
</CMSLayout>

<style>
  .analytics-page { max-width: 760px; padding: 20px 0; }
  h1 { margin: 0 0 20px; color: #e0ed65; font-size: 42px; }
  p { margin: 0 0 28px; color: #f7f5f2; font-size: 18px; }
  a { display: inline-block; border-radius: 12px; background: #e0ed65; color: #151515; padding: 14px 20px; font-size: 16px; font-weight: 800; text-decoration: none; }
</style>
