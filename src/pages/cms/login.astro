---
import BaseLayout from "@layouts/BaseLayout.astro";
---
<BaseLayout title="Login · Pedro Marques">
  <main class="login"><section><h1>PEDRO<span>.MARQUES</span></h1><form id="login"><label>E-mail<input required type="email" name="email" autocomplete="email" /></label><label>Senha<input required type="password" name="password" autocomplete="current-password" /></label><p id="error" role="alert"></p><button>Entrar</button></form></section></main>
</BaseLayout>
<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const form = document.querySelector<HTMLFormElement>("#login");
  const error = document.querySelector<HTMLElement>("#error");
  const { data: { session } } = await supabase.auth.getSession();
  if (session) location.href = "/cms/projetos";

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const button = form.querySelector<HTMLButtonElement>("button");
    if (button) button.disabled = true;
    if (error) error.textContent = "";
    const data = new FormData(form);
    const { error: loginError } = await supabase.auth.signInWithPassword({
      email: String(data.get("email") ?? ""),
      password: String(data.get("password") ?? ""),
    });
    if (loginError) {
      if (error) error.textContent = "E-mail ou senha inválidos.";
      if (button) button.disabled = false;
      return;
    }
    location.href = "/cms/projetos";
  });
</script>
<style>
  .login { min-height:100vh; display:grid; place-items:center; padding:24px; background:#232323; color:#f7f5f2; } section { width:min(100%, 540px); } h1 { text-align:center; font-size:37px; font-weight:900; margin:0 0 48px; } h1 span { color:#e0ed65; } form { border:1px solid #5a5a5a; border-radius:12px; padding:22px; display:grid; gap:24px; } label { display:grid; gap:8px; font-weight:800; text-transform:uppercase; font-size:13px; } input { padding:13px; border:0; border-radius:11px; background:#f3efeb; font:inherit; color:#222; } button { justify-self:end; min-width:200px; padding:12px 20px; border:0; border-radius:14px; background:#e0ed65; color:#111; font-weight:900; cursor:pointer; } small { display:block; text-align:center; margin-top:16px; color:#bdb7b4; } #error { color:#ff697a; margin:0; }
</style>
