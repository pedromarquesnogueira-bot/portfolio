---
interface Props { page: "projects" | "experience" | "tags" | "tools" | "settings"; mode?: "list" | "form"; }
const { page, mode = "list" } = Astro.props;
---

<section class="cms-panel" data-page={page} data-mode={mode}>
  <noscript>Ative o JavaScript para usar o painel administrativo.</noscript>
</section>
<p id="cms-feedback" role="status" aria-live="polite"></p>

<script>
  import { createClient } from "@supabase/supabase-js";

  type Tag = { id: string; name: string; nameEn: string };
  type Tool = { id: string; name: string; iconUrl: string };
  type Project = { id: string; title: string; titleEn: string; client: string; description: string; descriptionEn: string; status: "draft" | "published"; createdAt: string; tags: string[]; tools: string[]; media: string[]; coverImage: string };
  type Experience = { id: string; company: string; role: string; roleEn: string; description: string; descriptionEn: string; start: string; end: string; current: boolean; status: "draft" | "published" };
  type Store = { tags: Tag[]; tools: Tool[]; projects: Project[]; experiences: Experience[]; settings: Record<string, string> };
  const key = "pedro-portfolio-cms-v1";
  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const uid = () => crypto.randomUUID();
  const defaults = (): Store => ({
    tags: [{ id: uid(), name: "Branding", nameEn: "Branding" }, { id: uid(), name: "Design digital", nameEn: "Digital design" }, { id: uid(), name: "Social media", nameEn: "Social media" }],
    tools: [],
    projects: [], experiences: [], settings: { name: "Pedro Marques", role: "Designer", roleEn: "", email: "", whatsapp: "", linkedin: "", behance: "", about: "", aboutEn: "", siteTitle: "Pedro Marques", siteTitleEn: "", seoDescription: "", seoDescriptionEn: "", keywords: "", keywordsEn: "" }
  });
  const load = (): Store => { try { return JSON.parse(localStorage.getItem(key) || "") as Store; } catch { const data = defaults(); localStorage.setItem(key, JSON.stringify(data)); return data; } };
  const slugify = (value: string) => value.normalize("NFD").replace(/[\u0300-\u036f]/g, "").toLowerCase().trim().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
  const monthToDate = (value: string) => value ? `${value.slice(0, 7)}-01` : null;
  const showFeedback = (message: string) => { const element = document.querySelector<HTMLElement>("#cms-feedback"); if (element) element.textContent = message; };
  const dbError = (error: { message: string } | null) => {
    if (error) throw new Error(error.message);
  };
  async function uploadFile(file: File) {
    const upload = new FormData();
    upload.append("file", file);
    const response = await fetch("/api/upload/image", { method: "POST", body: upload });
    if (!response.ok) throw new Error(`Não foi possível enviar “${file.name}”.`);
    const uploaded = await response.json();
    if (!uploaded.secure_url) throw new Error(`O envio de “${file.name}” não foi concluído.`);
    return String(uploaded.secure_url);
  }
  type SaveScope = "tags" | "tools" | "project" | "projects-order" | "experience" | "experiences-order" | "settings";
  async function save(store: Store, scope: SaveScope, id = "") {
    showFeedback("Salvando alterações...");
    await sync(store, scope, id);
    localStorage.setItem(key, JSON.stringify(store));
    showFeedback("Alterações salvas.");
  }
  async function deleteRemote(type: string, id: string) {
    if (type === "tag") {
      dbError((await supabase.from("project_tags").delete().eq("tag_id", id)).error);
      dbError((await supabase.from("tags").delete().eq("id", id)).error);
    }
    if (type === "tool") {
      dbError((await supabase.from("project_tools").delete().eq("tool_id", id)).error);
      dbError((await supabase.from("tools").delete().eq("id", id)).error);
    }
    if (type === "project") {
      dbError((await supabase.from("project_tags").delete().eq("project_id", id)).error);
      dbError((await supabase.from("project_tools").delete().eq("project_id", id)).error);
      dbError((await supabase.from("project_images").delete().eq("project_id", id)).error);
      dbError((await supabase.from("projects").delete().eq("id", id)).error);
    }
    if (type === "experience") dbError((await supabase.from("experiences").delete().eq("id", id)).error);
  }
  async function sync(store: Store, scope: SaveScope, id = "") {
    const tagRows = store.tags.map(tag => ({ id: tag.id, name: tag.name, name_en: tag.nameEn || null, slug: slugify(tag.name) }));
    const toolRows = store.tools.map(tool => ({ id: tool.id, name: tool.name, slug: slugify(tool.name), icon_url: tool.iconUrl || null }));
    const projectRows = store.projects.map((project, sort_order) => ({ id: project.id, title: project.title, title_en: project.titleEn || null, slug: slugify(project.title), client: project.client || null, description: project.description || null, description_en: project.descriptionEn || null, cover_image: project.coverImage || null, published: project.status === "published", featured: false, sort_order }));
    const experienceRows = store.experiences.map((experience, sort_order) => ({ id: experience.id, company: experience.company, position: experience.role, position_en: experience.roleEn || null, description: experience.description || null, description_en: experience.descriptionEn || null, start_date: monthToDate(experience.start), end_date: experience.current ? null : monthToDate(experience.end), current_job: experience.current, published: experience.status === "published", sort_order }));
    const settings = store.settings;
    if (scope === "tags" && tagRows.length) dbError((await supabase.from("tags").upsert(tagRows)).error);
    if (scope === "tools" && toolRows.length) dbError((await supabase.from("tools").upsert(toolRows)).error);
    if (scope === "projects-order" && projectRows.length) dbError((await supabase.from("projects").upsert(projectRows)).error);
    if (scope === "experiences-order" && experienceRows.length) dbError((await supabase.from("experiences").upsert(experienceRows)).error);
    if (scope === "experience") {
      const row = experienceRows.find(item => item.id === id);
      if (row) dbError((await supabase.from("experiences").upsert(row)).error);
    }
    if (scope === "settings") dbError((await supabase.from("site_settings").upsert({ id: true, name: settings.name, role: settings.role, role_en: settings.roleEn || null, email: settings.email || null, whatsapp: settings.whatsapp || null, linkedin: settings.linkedin || null, behance: settings.behance || null, about_pt: settings.about || null, about_en: settings.aboutEn || null, seo_title_pt: settings.siteTitle || null, seo_title_en: settings.siteTitleEn || null, seo_description_pt: settings.seoDescription || null, seo_description_en: settings.seoDescriptionEn || null, seo_keywords_pt: settings.keywords || null, seo_keywords_en: settings.keywordsEn || null })).error);
    if (scope === "project") {
      const project = store.projects.find(item => item.id === id);
      const row = projectRows.find(item => item.id === id);
      if (!project || !row) return;
      dbError((await supabase.from("projects").upsert(row)).error);
      dbError((await supabase.from("project_tags").delete().eq("project_id", id)).error);
      dbError((await supabase.from("project_tools").delete().eq("project_id", id)).error);
      dbError((await supabase.from("project_images").delete().eq("project_id", id)).error);
      const projectTags = Array.isArray(project.tags) ? project.tags : [];
      const projectTools = Array.isArray(project.tools) ? project.tools : [];
      const projectMedia = Array.isArray(project.media) ? project.media : [];
      if (projectTags.length) dbError((await supabase.from("project_tags").insert(projectTags.map(tag_id => ({ project_id: project.id, tag_id })))).error);
      if (projectTools.length) dbError((await supabase.from("project_tools").insert(projectTools.map(tool_id => ({ project_id: project.id, tool_id })))).error);
      if (projectMedia.length) dbError((await supabase.from("project_images").insert(projectMedia.map((image_url, sort_order) => ({ project_id: project.id, image_url, sort_order })))).error);
    }
  }
  async function hydrate() {
    const [tags, tools, projects, projectMedia, experiences, settings, projectTags, projectTools] = await Promise.all([
      supabase.from("tags").select("id,name,name_en").order("name"), supabase.from("tools").select("id,name,icon_url").order("name"),
      supabase.from("projects").select("id,title,title_en,client,description,description_en,cover_image,published,created_at").order("sort_order"), supabase.from("project_images").select("project_id,image_url").order("sort_order"),
      supabase.from("experiences").select("id,company,position,position_en,description,description_en,start_date,end_date,current_job,published").order("sort_order"),
      supabase.from("site_settings").select("*").eq("id", true).maybeSingle(), supabase.from("project_tags").select("project_id,tag_id"), supabase.from("project_tools").select("project_id,tool_id"),
    ]);
    if (tags.error || tools.error || projects.error || experiences.error) return;
    const site = settings.data ?? {};
    const cached = load();
    const remoteRelations = (projectMedia.data?.length ?? 0) + (projectTags.data?.length ?? 0) + (projectTools.data?.length ?? 0);
    const cachedRelations = cached.projects.reduce((total, project) => total + (project.media?.length ?? 0) + (project.tags?.length ?? 0) + (project.tools?.length ?? 0), 0);
    // Se uma leitura antiga terminar enquanto um salvamento ainda está inserindo os vínculos,
    // conserva a cópia local mais completa em vez de apagar imagens, tags e ferramentas.
    const recoverCachedRelations = remoteRelations === 0 && cachedRelations > 0;
    const remote: Store = {
      tags: (tags.data ?? []).map(tag => ({ id: tag.id, name: tag.name, nameEn: tag.name_en ?? "" })), tools: (tools.data ?? []).map(tool => ({ id: tool.id, name: tool.name, iconUrl: tool.icon_url ?? "" })),
      projects: (projects.data ?? []).map(project => {
        const cachedProject = cached.projects.find(item => item.id === project.id);
        return { id: project.id, title: project.title, titleEn: project.title_en ?? "", client: project.client ?? "", description: project.description ?? "", descriptionEn: project.description_en ?? "", status: project.published ? "published" : "draft", createdAt: project.created_at ?? new Date().toISOString(), tags: recoverCachedRelations ? (cachedProject?.tags ?? []) : (projectTags.data ?? []).filter(row => row.project_id === project.id).map(row => row.tag_id), tools: recoverCachedRelations ? (cachedProject?.tools ?? []) : (projectTools.data ?? []).filter(row => row.project_id === project.id).map(row => row.tool_id), media: recoverCachedRelations ? (cachedProject?.media ?? []) : (projectMedia.data ?? []).filter(image => image.project_id === project.id).map(image => image.image_url), coverImage: project.cover_image ?? "" };
      }),
      experiences: (experiences.data ?? []).map(experience => ({ id: experience.id, company: experience.company, role: experience.position, roleEn: experience.position_en ?? "", description: experience.description ?? "", descriptionEn: experience.description_en ?? "", start: experience.start_date?.slice(0, 7) ?? "", end: experience.end_date?.slice(0, 7) ?? "", current: Boolean(experience.current_job), status: experience.published ? "published" : "draft" })),
      settings: { name: site.name ?? "Pedro Marques", role: site.role ?? "", roleEn: site.role_en ?? "", email: site.email ?? "", whatsapp: site.whatsapp ?? "", linkedin: site.linkedin ?? "", behance: site.behance ?? "", about: site.about_pt ?? "", aboutEn: site.about_en ?? "", siteTitle: site.seo_title_pt ?? "", siteTitleEn: site.seo_title_en ?? "", seoDescription: site.seo_description_pt ?? "", seoDescriptionEn: site.seo_description_en ?? "", keywords: site.seo_keywords_pt ?? "", keywordsEn: site.seo_keywords_en ?? "" },
    };
    localStorage.setItem(key, JSON.stringify(remote));
    if (recoverCachedRelations) {
      showFeedback("Restaurando imagens, tags e ferramentas...");
      for (const project of remote.projects) await sync(remote, "project", project.id);
      showFeedback("Imagens, tags e ferramentas restauradas.");
    }
    render();
  }
  const esc = (value = "") => value.replace(/[&<>'"]/g, char => ({ "&":"&amp;", "<":"&lt;", ">":"&gt;", "'":"&#39;", '"':"&quot;" })[char] || char);
  const page = document.querySelector<HTMLElement>(".cms-panel");
  const pageName = page?.dataset.page || "projects";
  const initialForm = page?.dataset.mode === "form";
  let projectForm = initialForm;
  let experienceForm = initialForm;
  let editingId = "";
  let editingTagId = "";
  let selectedMedia: File[] = [];
  let removedMedia = new Set<string>();

  const status = (value: "draft" | "published") => `<span class="status ${value}">${value === "published" ? "Publicado" : "Rascunho"}</span>`;
  const action = (label: string, name: string, id = "", extra = "") => `<button type="button" class="icon-button" data-action="${name}" data-id="${id}" ${extra} aria-label="${label}">${label}</button>`;
  const header = (title: string, button?: string) => `<header class="page-header"><h1>${title}</h1>${button ? `<button class="primary" type="button" data-action="${button}">${button}</button>` : ""}</header>`;
  const drag = (kind: string, id: string) => `draggable="true" data-drag-kind="${kind}" data-id="${id}"`;
  function renderProjects(store: Store) {
    if (projectForm) {
      const item = store.projects.find(p => p.id === editingId);
      const selectedTags = new Set(item?.tags || []), selectedTools = new Set(item?.tools || []);
      return `${header(item ? "Editar projeto" : "Novo projeto")}
        <form data-form="project" class="editor"><div class="form-grid two"><label>Título do projeto<input required name="title" value="${esc(item?.title)}"></label><label>Cliente<input name="client" value="${esc(item?.client)}"></label></div>
        <label>Descrição<textarea name="description" rows="6">${esc(item?.description)}</textarea></label>
        <fieldset><legend>Versão em inglês</legend><div class="form-grid two"><label>Título do projeto em inglês<input name="titleEn" value="${esc(item?.titleEn)}" placeholder="Ex.: Brand campaign"></label><label>Descrição em inglês<textarea name="descriptionEn" rows="4" placeholder="English description">${esc(item?.descriptionEn)}</textarea></label></div></fieldset>
        <div class="split"><fieldset><legend>Tags</legend>${store.tags.length ? store.tags.map(t => `<label class="check"><input type="checkbox" name="tags" value="${t.id}" ${selectedTags.has(t.id) ? "checked" : ""}>${esc(t.name)}</label>`).join("") : "<p>Cadastre tags antes de associá-las.</p>"}</fieldset><fieldset><legend>Ferramentas</legend>${store.tools.length ? store.tools.map(t => `<label class="check"><input type="checkbox" name="tools" value="${t.id}" ${selectedTools.has(t.id) ? "checked" : ""}>${esc(t.name)}</label>`).join("") : "<p>Cadastre ferramentas antes de associá-las.</p>"}</fieldset></div>
        <label class="upload">Thumbnail da galeria<input data-thumbnail-input type="file" name="thumbnail" accept="image/png,image/jpeg,image/webp" ${item?.coverImage ? "" : "required"}><span>Imagem de capa que aparecerá no card do projeto.</span><div class="thumbnail-preview">${item?.coverImage ? `<img src="${item.coverImage}" alt="Thumbnail atual">` : ""}</div></label>
        <label class="upload">Galeria de mídias<input data-media-input type="file" name="media" multiple accept="image/*,video/*"><span>Selecione imagens ou vídeos para o projeto e arraste as miniaturas para definir a sequência.</span><div class="media-preview">${(item?.media ?? []).filter(url => !removedMedia.has(url)).map((url, index) => `<div class="media-item"><img draggable="true" data-media-index="${index}" src="${url}" alt="Mídia ${index + 1}"><button type="button" class="remove-media" data-remove-existing-media data-url="${esc(url)}" aria-label="Remover mídia">×</button></div>`).join("")}</div></label>
        <label class="upload">Recuperar mídias do Cloudinary<textarea name="existingMedia" rows="4" placeholder="Cole aqui uma URL por linha"></textarea><span>Use este campo para reutilizar imagens que já estão no Cloudinary, sem fazer novo upload.</span></label>
        <div class="form-actions"><button type="button" class="secondary" data-action="cancel-project">Cancelar</button><button class="secondary" name="intent" value="draft">Salvar rascunho</button><button class="primary" name="intent" value="published">Salvar e publicar</button></div></form>`;
    }
    return `${header("Projetos", "Adicionar projeto")}<div class="table-wrap"><table><thead><tr><th></th><th>Projeto</th><th>Cliente</th><th>Data</th><th>Status</th><th>Ações</th></tr></thead><tbody>${store.projects.length ? store.projects.map(p => `<tr ${drag("projects", p.id)}><td class="grip">⠿</td><td><strong>${esc(p.title)}</strong></td><td>${esc(p.client || "—")}</td><td>${new Date(p.createdAt).toLocaleDateString("pt-BR")}</td><td>${status(p.status)}</td><td>${action("Editar", "edit-project", p.id)} ${action("Excluir", "delete-project", p.id)}</td></tr>`).join("") : `<tr><td colspan="6" class="empty">Ainda não há projetos. Clique em “Adicionar projeto”.</td></tr>`}</tbody></table></div>`;
  }
  function renderTags(store: Store) {
    const item = store.tags.find(tag => tag.id === editingTagId);
    return `${header("Tags")}<div class="two-columns"><form data-form="tag" class="card"><h2>${item ? "Editar tag" : "Nova tag"}</h2><label>Nome da tag<input required name="name" value="${esc(item?.name)}" placeholder="Ex.: Design gráfico"></label><label>Nome da tag em inglês<input name="nameEn" value="${esc(item?.nameEn)}" placeholder="Ex.: Graphic design"></label><p class="hint">O nome em inglês será exibido no site em inglês.</p><div class="form-actions">${item ? `<button type="button" class="secondary" data-action="cancel-tag">Cancelar</button>` : ""}<button class="primary">${item ? "Atualizar tag" : "Salvar tag"}</button></div></form><section class="card"><h2>Lista de tags</h2><ul class="plain-list">${store.tags.map(t => `<li><span class="tag-label"><strong>${esc(t.name)}</strong><small>${esc(t.nameEn || "Sem versão em inglês")}</small></span>${action("Editar", "edit-tag", t.id)}${action("Excluir", "delete-tag", t.id)}</li>`).join("") || "<li>Nenhuma tag cadastrada.</li>"}</ul></section></div>`;
  }
  function renderTools(store: Store) { return `${header("Ferramentas")}<div class="two-columns"><form data-form="tool" class="card"><label>Nome da ferramenta<input required name="name" placeholder="Ex.: Photoshop"></label><label>Ícone da ferramenta<input required name="icon" type="file" accept="image/png,image/jpeg,image/svg+xml,image/webp"><span class="hint">PNG, JPG, SVG ou WebP.</span></label><button class="primary">Salvar ferramenta</button></form><section class="card"><h2>Lista de ferramentas</h2><ul class="plain-list">${store.tools.map(t => `<li>${t.iconUrl ? `<img class="tool-icon" src="${esc(t.iconUrl)}" alt="">` : `<span class="tool-icon placeholder">?</span>`}${esc(t.name)}${action("Excluir", "delete-tool", t.id)}</li>`).join("") || "<li>Nenhuma ferramenta cadastrada.</li>"}</ul></section></div>`; }
  function renderExperience(store: Store) {
    if (experienceForm) { const item = store.experiences.find(e => e.id === editingId); return `${header(item ? "Editar experiência" : "Nova experiência")}<form data-form="experience" class="editor"><div class="form-grid two"><label>Nome da empresa<input required name="company" value="${esc(item?.company)}"></label><label>Cargo<input required name="role" value="${esc(item?.role)}"></label><label>Data de início<input required type="month" name="start" value="${esc(item?.start)}"></label><label>Data final<input type="month" name="end" value="${esc(item?.end)}"></label></div><label class="check"><input type="checkbox" name="current" ${item?.current ? "checked" : ""}> Experiência atual</label><label>Descrição<textarea name="description" rows="6">${esc(item?.description)}</textarea></label><fieldset><legend>Versão em inglês</legend><div class="form-grid two"><label>Cargo em inglês<input name="roleEn" value="${esc(item?.roleEn)}" placeholder="Ex.: Art Director"></label><label>Descrição em inglês<textarea name="descriptionEn" rows="4" placeholder="English description">${esc(item?.descriptionEn)}</textarea></label></div></fieldset><div class="form-actions"><button type="button" class="secondary" data-action="cancel-experience">Cancelar</button><button class="secondary" name="intent" value="draft">Salvar rascunho</button><button class="primary" name="intent" value="published">Salvar e publicar</button></div></form>`; }
    return `${header("Experiência", "Adicionar experiência")}<div class="table-wrap"><table><thead><tr><th></th><th>Empresa</th><th>Cargo</th><th>Período</th><th>Status</th><th>Ações</th></tr></thead><tbody>${store.experiences.length ? store.experiences.map(e => `<tr ${drag("experiences", e.id)}><td class="grip">⠿</td><td><strong>${esc(e.company)}</strong></td><td>${esc(e.role)}</td><td>${e.current ? `${e.start} — atual` : `${e.start} — ${e.end || "—"}`}</td><td>${status(e.status)}</td><td>${action("Editar", "edit-experience", e.id)} ${action("Excluir", "delete-experience", e.id)}</td></tr>`).join("") : `<tr><td colspan="6" class="empty">Nenhuma experiência cadastrada.</td></tr>`}</tbody></table></div>`;
  }
  function renderSettings(store: Store) { const s = store.settings; return `${header("Configurações")}<form data-form="settings" class="settings"><section class="card"><h2>Dados pessoais</h2><div class="form-grid"><label>Nome<input name="name" value="${esc(s.name)}"></label><label>Cargo<input name="role" value="${esc(s.role)}"></label><label>E-mail<input name="email" type="email" value="${esc(s.email)}"></label><label>WhatsApp<input name="whatsapp" value="${esc(s.whatsapp)}"></label><label>LinkedIn<input name="linkedin" value="${esc(s.linkedin)}"></label><label>Behance<input name="behance" value="${esc(s.behance)}"></label></div><label>Texto sobre mim<textarea name="about" rows="7">${esc(s.about)}</textarea></label><fieldset><legend>Versão em inglês</legend><label>Cargo em inglês<input name="roleEn" value="${esc(s.roleEn)}"></label><label>Texto sobre mim em inglês<textarea name="aboutEn" rows="7">${esc(s.aboutEn)}</textarea></label></fieldset></section><section class="card"><h2>SEO</h2><label>Título do site<input name="siteTitle" value="${esc(s.siteTitle)}"></label><label>Descrição<textarea name="seoDescription" rows="4">${esc(s.seoDescription)}</textarea></label><label>Palavras-chave<input name="keywords" value="${esc(s.keywords)}"></label><fieldset><legend>SEO em inglês</legend><label>Título do site em inglês<input name="siteTitleEn" value="${esc(s.siteTitleEn)}"></label><label>Descrição em inglês<textarea name="seoDescriptionEn" rows="4">${esc(s.seoDescriptionEn)}</textarea></label><label>Palavras-chave em inglês<input name="keywordsEn" value="${esc(s.keywordsEn)}"></label></fieldset><p class="hint">Os uploads de hero banner e favicon serão ativados ao configurar o Cloudinary.</p></section><div class="form-actions"><button class="primary">Salvar e publicar</button></div></form>`; }
  function render() { if (!page) return; const store = load(); page.innerHTML = pageName === "tags" ? renderTags(store) : pageName === "tools" ? renderTools(store) : pageName === "experience" ? renderExperience(store) : pageName === "settings" ? renderSettings(store) : renderProjects(store); bind(); }
  function bind() {
    page?.querySelectorAll<HTMLElement>("[draggable]").forEach(row => { row.addEventListener("dragstart", event => event.dataTransfer?.setData("text/plain", row.dataset.id || "")); row.addEventListener("dragover", event => event.preventDefault()); row.addEventListener("drop", event => { event.preventDefault(); const source = event.dataTransfer?.getData("text/plain"), kind = row.dataset.dragKind; if (!source || !kind || source === row.dataset.id) return; const store = load(), list = kind === "projects" ? store.projects : store.experiences; const a = list.findIndex(x => x.id === source), b = list.findIndex(x => x.id === row.dataset.id); if (a >= 0 && b >= 0) { list.splice(b, 0, list.splice(a, 1)[0]); save(store, kind === "projects" ? "projects-order" : "experiences-order"); render(); } }); });
    const thumbnail = page?.querySelector<HTMLInputElement>("[data-thumbnail-input]"); const thumbnailPreview = page?.querySelector<HTMLElement>(".thumbnail-preview");
    thumbnail?.addEventListener("change", () => { const file = thumbnail.files?.[0]; if (file && thumbnailPreview) thumbnailPreview.innerHTML = `<img src="${URL.createObjectURL(file)}" alt="Prévia da thumbnail">`; });
    const mediaInput = page?.querySelector<HTMLInputElement>("[data-media-input]"); const mediaPreview = page?.querySelector<HTMLElement>(".media-preview");
    const drawMedia = () => { if (mediaPreview) mediaPreview.innerHTML = selectedMedia.map((file, index) => `<div class="media-item"><img draggable="true" data-file-index="${index}" src="${URL.createObjectURL(file)}" alt="Prévia ${index + 1}"><button type="button" class="remove-media" data-remove-file-index="${index}" aria-label="Remover mídia">×</button></div>`).join(""); };
    mediaInput?.addEventListener("change", () => { selectedMedia = Array.from(mediaInput.files ?? []); drawMedia(); });
    mediaPreview?.addEventListener("click", event => { const button = (event.target as HTMLElement).closest<HTMLButtonElement>(".remove-media"); if (!button) return; const url = button.dataset.url; const fileIndex = button.dataset.removeFileIndex; if (url) { removedMedia.add(url); button.closest<HTMLElement>(".media-item")?.remove(); } if (fileIndex !== undefined) { selectedMedia.splice(Number(fileIndex), 1); const transfer = new DataTransfer(); selectedMedia.forEach(file => transfer.items.add(file)); if (mediaInput) mediaInput.files = transfer.files; drawMedia(); } });
    mediaPreview?.addEventListener("dragstart", event => event.dataTransfer?.setData("text/plain", (event.target as HTMLElement).dataset.fileIndex || ""));
    mediaPreview?.addEventListener("dragover", event => event.preventDefault()); mediaPreview?.addEventListener("drop", event => { event.preventDefault(); const from = Number(event.dataTransfer?.getData("text/plain")); const target = (event.target as HTMLElement).closest<HTMLElement>("[data-file-index]"); const to = Number(target?.dataset.fileIndex); if (Number.isInteger(from) && Number.isInteger(to) && from !== to) { selectedMedia.splice(to, 0, selectedMedia.splice(from, 1)[0]); const transfer = new DataTransfer(); selectedMedia.forEach(file => transfer.items.add(file)); if (mediaInput) mediaInput.files = transfer.files; drawMedia(); } });
  }
  page?.addEventListener("click", async event => {
    const target = (event.target as HTMLElement).closest<HTMLElement>("[data-action]");
    if (!target) return;
    const actionName = target.dataset.action || "", id = target.dataset.id || "";
    const store = load();
    if (actionName === "Adicionar projeto") { projectForm = true; editingId = ""; selectedMedia = []; removedMedia = new Set(); render(); return; }
    if (actionName === "Adicionar experiência") { experienceForm = true; editingId = ""; render(); return; }
    if (actionName === "cancel-project") { projectForm = false; selectedMedia = []; removedMedia = new Set(); render(); return; }
    if (actionName === "cancel-experience") { experienceForm = false; render(); return; }
    if (actionName === "cancel-tag") { editingTagId = ""; render(); return; }
    if (actionName === "edit-project") { projectForm = true; editingId = id; selectedMedia = []; removedMedia = new Set(); render(); return; }
    if (actionName === "edit-experience") { experienceForm = true; editingId = id; render(); return; }
    if (actionName === "edit-tag") { editingTagId = id; render(); return; }
    if (!actionName.startsWith("delete-") || !confirm("Excluir este registro?")) return;
    const type = actionName.replace("delete-", "");
    try {
      showFeedback("Excluindo...");
      await deleteRemote(type, id);
      if (type === "tag") store.tags = store.tags.filter(x => x.id !== id);
      if (type === "tool") store.tools = store.tools.filter(x => x.id !== id);
      if (type === "project") store.projects = store.projects.filter(x => x.id !== id);
      if (type === "experience") store.experiences = store.experiences.filter(x => x.id !== id);
      localStorage.setItem(key, JSON.stringify(store));
      showFeedback("Item excluído.");
      render();
    } catch (error) { console.error(error); showFeedback(error instanceof Error ? error.message : "Não foi possível excluir. Tente novamente."); }
  });
  page?.addEventListener("submit", async event => {
    event.preventDefault();
    const form = event.target as HTMLFormElement, data = new FormData(form), type = form.dataset.form || "", store = load();
    const submitter = (event as SubmitEvent).submitter;
    const intent = submitter instanceof HTMLButtonElement ? submitter.value : "published";
    try {
      showFeedback(type === "project" || type === "tool" ? "Enviando arquivos..." : "Preparando alterações...");
      if (type === "tag") {
        const item: Tag = { id: editingTagId || uid(), name: String(data.get("name")).trim(), nameEn: String(data.get("nameEn") || "").trim() };
        const index = store.tags.findIndex(tag => tag.id === item.id);
        index >= 0 ? store.tags.splice(index, 1, item) : store.tags.push(item);
        editingTagId = "";
      }
      if (type === "tool") {
        const file = data.get("icon");
        if (!(file instanceof File) || !file.size) return;
        store.tools.push({ id: uid(), name: String(data.get("name")), iconUrl: await uploadFile(file) });
      }
      if (type === "project") {
        const current = store.projects.find(p => p.id === editingId);
        const item: Project = { id: editingId || uid(), title: String(data.get("title")), titleEn: String(data.get("titleEn") || ""), client: String(data.get("client")), description: String(data.get("description")), descriptionEn: String(data.get("descriptionEn") || ""), status: intent === "draft" ? "draft" : "published", createdAt: current?.createdAt || new Date().toISOString(), tags: data.getAll("tags").map(String), tools: data.getAll("tools").map(String), media: (current?.media || []).filter(url => !removedMedia.has(url)), coverImage: current?.coverImage || "" };
        const thumbnail = data.get("thumbnail");
        if (thumbnail instanceof File && thumbnail.size) {
          item.coverImage = await uploadFile(thumbnail);
        }
        const files = data.getAll("media").filter(x => x instanceof File && x.size) as File[];
        const existingMedia = String(data.get("existingMedia") || "").split(/[\n,]/).map(url => url.trim()).filter(url => /^https?:\/\//i.test(url));
        if (files.length) item.media = [...item.media, ...await Promise.all(files.map(uploadFile))];
        item.media = [...new Set([...item.media, ...existingMedia])];
        const index = store.projects.findIndex(p => p.id === item.id);
        index >= 0 ? store.projects.splice(index, 1, item) : store.projects.unshift(item);
        editingId = item.id;
      }
      if (type === "experience") {
        const item: Experience = { id: editingId || uid(), company: String(data.get("company")), role: String(data.get("role")), roleEn: String(data.get("roleEn") || ""), description: String(data.get("description")), descriptionEn: String(data.get("descriptionEn") || ""), start: String(data.get("start")), end: String(data.get("end")), current: data.get("current") === "on", status: intent === "draft" ? "draft" : "published" };
        const index = store.experiences.findIndex(e => e.id === item.id);
        index >= 0 ? store.experiences.splice(index, 1, item) : store.experiences.unshift(item);
        editingId = item.id;
      }
      if (type === "settings") store.settings = { ...store.settings, ...Object.fromEntries(data.entries()) as Record<string, string> };
      const scope: SaveScope = type === "tag" ? "tags" : type === "tool" ? "tools" : type === "project" ? "project" : type === "experience" ? "experience" : "settings";
      await save(store, scope, editingId);
      if (type === "project") { projectForm = false; editingId = ""; selectedMedia = []; removedMedia = new Set(); }
      if (type === "experience") { experienceForm = false; editingId = ""; }
      render();
    } catch (error) {
      console.error(error);
      showFeedback(error instanceof Error ? error.message : "Não foi possível salvar. Tente novamente.");
    }
  });
  // Só desenha o painel após a leitura inicial. Assim uma resposta antiga não
  // consegue sobrescrever uma edição que acabou de ser salva.
  void hydrate().finally(render);
</script>

