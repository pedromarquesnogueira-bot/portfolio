---
interface Props { page: "projects" | "experience" | "tags" | "tools" | "settings"; mode?: "list" | "form"; }
const { page, mode = "list" } = Astro.props;
---

<section class="cms-panel" data-page={page} data-mode={mode}>
  <noscript>Ative o JavaScript para usar o painel administrativo.</noscript>
</section>

<script>
  type Tag = { id: string; name: string };
  type Tool = { id: string; name: string; color: string };
  type Project = { id: string; title: string; client: string; description: string; status: "draft" | "published"; createdAt: string; tags: string[]; tools: string[]; media: string[] };
  type Experience = { id: string; company: string; role: string; description: string; start: string; end: string; current: boolean; status: "draft" | "published" };
  type Store = { tags: Tag[]; tools: Tool[]; projects: Project[]; experiences: Experience[]; settings: Record<string, string> };
  const key = "pedro-portfolio-cms-v1";
  const uid = () => crypto.randomUUID();
  const defaults = (): Store => ({
    tags: [{ id: uid(), name: "Branding" }, { id: uid(), name: "Design digital" }, { id: uid(), name: "Social media" }],
    tools: [{ id: uid(), name: "Photoshop", color: "#31a8ff" }, { id: uid(), name: "Illustrator", color: "#ff9a00" }, { id: uid(), name: "Figma", color: "#e85d88" }],
    projects: [], experiences: [], settings: { name: "Pedro Marques", role: "Designer", email: "", whatsapp: "", linkedin: "", behance: "", about: "", siteTitle: "Pedro Marques", seoDescription: "", keywords: "" }
  });
  const load = (): Store => { try { return JSON.parse(localStorage.getItem(key) || "") as Store; } catch { const data = defaults(); localStorage.setItem(key, JSON.stringify(data)); return data; } };
  const save = (store: Store) => localStorage.setItem(key, JSON.stringify(store));
  const esc = (value = "") => value.replace(/[&<>'"]/g, char => ({ "&":"&amp;", "<":"&lt;", ">":"&gt;", "'":"&#39;", '"':"&quot;" })[char] || char);
  const page = document.querySelector<HTMLElement>(".cms-panel");
  const pageName = page?.dataset.page || "projects";
  const initialForm = page?.dataset.mode === "form";
  let projectForm = initialForm;
  let experienceForm = initialForm;
  let editingId = "";

  const status = (value: "draft" | "published") => `<span class="status ${value}">${value === "published" ? "Publicado" : "Rascunho"}</span>`;
  const action = (label: string, name: string, id = "", extra = "") => `<button type="button" class="icon-button" data-action="${name}" data-id="${id}" ${extra} aria-label="${label}">${label}</button>`;
  const header = (title: string, button?: string) => `<header class="page-header"><h1>${title}</h1>${button ? `<button class="primary" type="button" data-action="${button}">${button}</button>` : ""}</header>`;
  const drag = (kind: string, id: string) => `draggable="true" data-drag-kind="${kind}" data-id="${id}"`;
  function renderProjects(store: Store) {
    if (projectForm) {
      const item = store.projects.find(p => p.id === editingId);
      const selectedTags = new Set(item?.tags || []), selectedTools = new Set(item?.tools || []);
      return `${header(item ? "Editar projeto" : "Novo projeto")}
        <form data-form="project" class="editor"><div class="form-grid two"><label>Título do projeto<input required name="title" value="${esc(item?.title)}"></label><label>Cliente<input name="client" value="${esc(item?.client)}"></label></div>
        <label>Descrição<textarea name="description" rows="6">${esc(item?.description)}</textarea></label>
        <div class="split"><fieldset><legend>Tags</legend>${store.tags.length ? store.tags.map(t => `<label class="check"><input type="checkbox" name="tags" value="${t.id}" ${selectedTags.has(t.id) ? "checked" : ""}>${esc(t.name)}</label>`).join("") : "<p>Cadastre tags antes de associá-las.</p>"}</fieldset><fieldset><legend>Ferramentas</legend>${store.tools.length ? store.tools.map(t => `<label class="check"><input type="checkbox" name="tools" value="${t.id}" ${selectedTools.has(t.id) ? "checked" : ""}>${esc(t.name)}</label>`).join("") : "<p>Cadastre ferramentas antes de associá-las.</p>"}</fieldset></div>
        <label class="upload">Galeria de mídias<input type="file" name="media" multiple accept="image/*,video/*"><span>Selecione imagens ou vídeos. Os arquivos ficam apenas na demonstração local até configurar o Cloudinary.</span></label>
        <div class="form-actions"><button type="button" class="secondary" data-action="cancel-project">Cancelar</button><button class="secondary" name="intent" value="draft">Salvar rascunho</button><button class="primary" name="intent" value="published">Salvar e publicar</button></div></form>`;
    }
    return `${header("Projetos", "Adicionar projeto")}<div class="table-wrap"><table><thead><tr><th></th><th>Projeto</th><th>Cliente</th><th>Data</th><th>Status</th><th>Ações</th></tr></thead><tbody>${store.projects.length ? store.projects.map(p => `<tr ${drag("projects", p.id)}><td class="grip">⠿</td><td><strong>${esc(p.title)}</strong></td><td>${esc(p.client || "—")}</td><td>${new Date(p.createdAt).toLocaleDateString("pt-BR")}</td><td>${status(p.status)}</td><td>${action("Editar", "edit-project", p.id)} ${action("Excluir", "delete-project", p.id)}</td></tr>`).join("") : `<tr><td colspan="6" class="empty">Ainda não há projetos. Clique em “Adicionar projeto”.</td></tr>`}</tbody></table></div>`;
  }
  function renderTags(store: Store) { return `${header("Tags")}<div class="two-columns"><form data-form="tag" class="card"><label>Nome da tag<input required name="name" placeholder="Ex.: Design gráfico"></label><button class="primary">Salvar tag</button></form><section class="card"><h2>Lista de tags</h2><ul class="plain-list">${store.tags.map(t => `<li>${esc(t.name)}${action("Excluir", "delete-tag", t.id)}</li>`).join("") || "<li>Nenhuma tag cadastrada.</li>"}</ul></section></div>`; }
  function renderTools(store: Store) { return `${header("Ferramentas")}<div class="two-columns"><form data-form="tool" class="card"><label>Nome da ferramenta<input required name="name" placeholder="Ex.: Photoshop"></label><label>Cor do ícone<input name="color" type="color" value="#e0ed65"></label><button class="primary">Salvar ferramenta</button></form><section class="card"><h2>Lista de ferramentas</h2><ul class="plain-list">${store.tools.map(t => `<li><span class="tool-dot" style="background:${t.color}"></span>${esc(t.name)}${action("Excluir", "delete-tool", t.id)}</li>`).join("") || "<li>Nenhuma ferramenta cadastrada.</li>"}</ul></section></div>`; }
  function renderExperience(store: Store) {
    if (experienceForm) { const item = store.experiences.find(e => e.id === editingId); return `${header(item ? "Editar experiência" : "Nova experiência")}<form data-form="experience" class="editor"><div class="form-grid two"><label>Nome da empresa<input required name="company" value="${esc(item?.company)}"></label><label>Cargo<input required name="role" value="${esc(item?.role)}"></label><label>Data de início<input required type="month" name="start" value="${esc(item?.start)}"></label><label>Data final<input type="month" name="end" value="${esc(item?.end)}"></label></div><label class="check"><input type="checkbox" name="current" ${item?.current ? "checked" : ""}> Experiência atual</label><label>Descrição<textarea name="description" rows="6">${esc(item?.description)}</textarea></label><div class="form-actions"><button type="button" class="secondary" data-action="cancel-experience">Cancelar</button><button class="secondary" name="intent" value="draft">Salvar rascunho</button><button class="primary" name="intent" value="published">Salvar e publicar</button></div></form>`; }
    return `${header("Experiência", "Adicionar experiência")}<div class="table-wrap"><table><thead><tr><th></th><th>Empresa</th><th>Cargo</th><th>Período</th><th>Status</th><th>Ações</th></tr></thead><tbody>${store.experiences.length ? store.experiences.map(e => `<tr ${drag("experiences", e.id)}><td class="grip">⠿</td><td><strong>${esc(e.company)}</strong></td><td>${esc(e.role)}</td><td>${e.current ? `${e.start} — atual` : `${e.start} — ${e.end || "—"}`}</td><td>${status(e.status)}</td><td>${action("Editar", "edit-experience", e.id)} ${action("Excluir", "delete-experience", e.id)}</td></tr>`).join("") : `<tr><td colspan="6" class="empty">Nenhuma experiência cadastrada.</td></tr>`}</tbody></table></div>`;
  }
  function renderSettings(store: Store) { const s = store.settings; return `${header("Configurações")}<form data-form="settings" class="settings"><section class="card"><h2>Dados pessoais</h2><div class="form-grid"><label>Nome<input name="name" value="${esc(s.name)}"></label><label>Cargo<input name="role" value="${esc(s.role)}"></label><label>E-mail<input name="email" type="email" value="${esc(s.email)}"></label><label>WhatsApp<input name="whatsapp" value="${esc(s.whatsapp)}"></label><label>LinkedIn<input name="linkedin" value="${esc(s.linkedin)}"></label><label>Behance<input name="behance" value="${esc(s.behance)}"></label></div><label>Texto sobre mim<textarea name="about" rows="7">${esc(s.about)}</textarea></label></section><section class="card"><h2>SEO</h2><label>Título do site<input name="siteTitle" value="${esc(s.siteTitle)}"></label><label>Descrição<textarea name="seoDescription" rows="4">${esc(s.seoDescription)}</textarea></label><label>Palavras-chave<input name="keywords" value="${esc(s.keywords)}"></label><p class="hint">Os uploads de hero banner e favicon serão ativados ao configurar o Cloudinary.</p></section><div class="form-actions"><button class="primary">Salvar e publicar</button></div></form>`; }
  function render() { if (!page) return; const store = load(); page.innerHTML = pageName === "tags" ? renderTags(store) : pageName === "tools" ? renderTools(store) : pageName === "experience" ? renderExperience(store) : pageName === "settings" ? renderSettings(store) : renderProjects(store); bind(); }
  function bind() {
    page?.querySelectorAll<HTMLElement>("[draggable]").forEach(row => { row.addEventListener("dragstart", event => event.dataTransfer?.setData("text/plain", row.dataset.id || "")); row.addEventListener("dragover", event => event.preventDefault()); row.addEventListener("drop", event => { event.preventDefault(); const source = event.dataTransfer?.getData("text/plain"), kind = row.dataset.dragKind; if (!source || !kind || source === row.dataset.id) return; const store = load(), list = kind === "projects" ? store.projects : store.experiences; const a = list.findIndex(x => x.id === source), b = list.findIndex(x => x.id === row.dataset.id); if (a >= 0 && b >= 0) { list.splice(b, 0, list.splice(a, 1)[0]); save(store); render(); } }); });
  }
  page?.addEventListener("click", event => { const target = (event.target as HTMLElement).closest<HTMLElement>("[data-action]"); if (!target) return; const actionName = target.dataset.action || "", id = target.dataset.id || ""; const store = load(); if (actionName === "Adicionar projeto") { projectForm = true; editingId = ""; } else if (actionName === "Adicionar experiência") { experienceForm = true; editingId = ""; } else if (actionName === "cancel-project") projectForm = false; else if (actionName === "cancel-experience") experienceForm = false; else if (actionName === "edit-project") { projectForm = true; editingId = id; } else if (actionName === "edit-experience") { experienceForm = true; editingId = id; } else if (actionName.startsWith("delete-")) { const type = actionName.replace("delete-", ""); if (confirm("Excluir este registro?")) { if (type === "tag") store.tags = store.tags.filter(x => x.id !== id); if (type === "tool") store.tools = store.tools.filter(x => x.id !== id); if (type === "project") store.projects = store.projects.filter(x => x.id !== id); if (type === "experience") store.experiences = store.experiences.filter(x => x.id !== id); save(store); } } render(); });
  page?.addEventListener("submit", async event => { event.preventDefault(); const form = event.target as HTMLFormElement, data = new FormData(form), type = form.dataset.form || "", store = load(); const intent = (event as SubmitEvent).submitter instanceof HTMLButtonElement ? (event as SubmitEvent).submitter?.value : "published"; if (type === "tag") store.tags.push({ id: uid(), name: String(data.get("name")) }); if (type === "tool") store.tools.push({ id: uid(), name: String(data.get("name")), color: String(data.get("color")) }); if (type === "project") { const item: Project = { id: editingId || uid(), title: String(data.get("title")), client: String(data.get("client")), description: String(data.get("description")), status: intent === "draft" ? "draft" : "published", createdAt: editingId ? (store.projects.find(p => p.id === editingId)?.createdAt || new Date().toISOString()) : new Date().toISOString(), tags: data.getAll("tags").map(String), tools: data.getAll("tools").map(String), media: [] }; const files = data.getAll("media").filter(x => x instanceof File) as File[]; item.media = await Promise.all(files.filter(f => f.size).map(f => new Promise<string>(resolve => { const reader = new FileReader(); reader.onload = () => resolve(String(reader.result)); reader.readAsDataURL(f); }))); const index = store.projects.findIndex(p => p.id === item.id); index >= 0 ? store.projects.splice(index, 1, item) : store.projects.unshift(item); projectForm = false; editingId = ""; } if (type === "experience") { const item: Experience = { id: editingId || uid(), company: String(data.get("company")), role: String(data.get("role")), description: String(data.get("description")), start: String(data.get("start")), end: String(data.get("end")), current: data.get("current") === "on", status: intent === "draft" ? "draft" : "published" }; const index = store.experiences.findIndex(e => e.id === item.id); index >= 0 ? store.experiences.splice(index, 1, item) : store.experiences.unshift(item); experienceForm = false; editingId = ""; } if (type === "settings") store.settings = { ...store.settings, ...Object.fromEntries(data.entries()) as Record<string, string> }; save(store); render(); });
  render();
</script>

<style>
  .cms-panel { max-width: 1140px; margin: 0 auto; } :global(.page-header) { display:flex; justify-content:space-between; align-items:center; gap:20px; margin-bottom:30px; } :global(h1) { color:#e0ed65; font-size:30px; text-transform:uppercase; margin:0; letter-spacing:-1px; } :global(h2) { margin:0 0 22px; font-size:17px; text-transform:uppercase; } :global(.primary), :global(.secondary), :global(.icon-button) { border:0; cursor:pointer; font-weight:800; } :global(.primary) { background:#e0ed65; color:#121212; border-radius:14px; min-width:220px; padding:12px 22px; } :global(.secondary) { background:#aaa5a5; color:#fff; border-radius:14px; padding:12px 22px; } :global(.two-columns), :global(.split) { display:grid; grid-template-columns:1fr 1fr; gap:22px; } :global(.card), :global(.editor) { border:1px solid #555; border-radius:12px; padding:22px; background:#252525; } :global(form) { display:grid; gap:18px; } :global(label) { display:grid; gap:8px; font-weight:800; font-size:13px; text-transform:uppercase; } :global(input), :global(textarea) { background:#f3efeb; border:0; color:#242424; border-radius:11px; padding:12px 14px; width:100%; text-transform:none; font-weight:500; } :global(textarea) { resize:vertical; } :global(.form-grid) { display:grid; grid-template-columns:1fr 1fr; gap:18px; } :global(.form-grid.two) { grid-template-columns:repeat(2, 1fr); } :global(fieldset) { border:1px solid #555; border-radius:10px; display:grid; gap:9px; } :global(legend) { font-weight:800; text-transform:uppercase; font-size:13px; } :global(.check) { display:flex; align-items:center; gap:9px; text-transform:none; } :global(.check input) { width:auto; } :global(.upload) { border:1px dashed #777; padding:18px; border-radius:10px; } :global(.upload span), :global(.hint) { font-size:13px; color:#c0bbbb; text-transform:none; font-weight:400; } :global(.form-actions) { display:flex; justify-content:flex-end; gap:14px; flex-wrap:wrap; } :global(.table-wrap) { overflow:auto; border:1px solid #555; border-radius:12px; } :global(table) { width:100%; border-collapse:collapse; min-width:720px; } :global(th), :global(td) { text-align:left; padding:17px; border-bottom:1px solid #555; } :global(th) { font-size:14px; font-weight:500; } :global(td) { font-size:15px; } :global(.grip) { color:#a7a0a0; cursor:grab; font-size:22px; } :global(.empty) { text-align:center; color:#c4bebe; padding:36px; } :global(.status) { display:inline-block; border-radius:999px; padding:6px 10px; font-size:12px; font-weight:800; } :global(.status.published) { background:#e0ed65; color:#171717; } :global(.status.draft) { background:#777; color:#fff; } :global(.icon-button) { background:#484848; color:#fff; border-radius:7px; padding:7px 9px; font-size:12px; margin-right:5px; } :global(.plain-list) { margin:0; padding:0; list-style:none; } :global(.plain-list li) { min-height:58px; display:flex; align-items:center; gap:12px; border-bottom:1px solid #666; font-size:16px; } :global(.plain-list .icon-button) { margin-left:auto; } :global(.tool-dot) { display:inline-block; width:30px; height:30px; border-radius:6px; } :global(.settings) { grid-template-columns:1fr 1fr; align-items:start; } :global(.settings > .form-actions) { grid-column:1 / -1; } @media(max-width:780px) { :global(.two-columns), :global(.split), :global(.settings), :global(.form-grid), :global(.form-grid.two) { grid-template-columns:1fr; } :global(.page-header) { align-items:flex-start; flex-direction:column; } :global(.primary) { min-width:0; width:100%; } }
</style>
