---
import BaseLayout from "./BaseLayout.astro";

const { pathname } = Astro.url;
const links = [
  ["Projetos", "/cms/projetos"],
  ["Experiência", "/cms/experiencia"],
  ["Tags", "/cms/tags"],
  ["Ferramentas", "/cms/ferramentas"],
  ["Configurações", "/cms/configuracoes"],
] as const;
---

<BaseLayout title="CMS · Pedro Marques">
  <div class="shell">
    <aside class="sidebar">
      <a class="brand" href="/cms/projetos" aria-label="Início do CMS">PEDRO<span>.MARQUES</span></a>
      <nav aria-label="Navegação do CMS">
        {links.map(([label, href]) => <a class:list={{ active: pathname === href || (href === "/cms/projetos" && pathname.startsWith("/cms/projetos")) }} href={href}>{label}</a>)}
      </nav>
      <a class="logout" href="/cms/login" data-logout>Logout</a>
    </aside>
    <main class="main"><slot /></main>
  </div>
</BaseLayout>

<script>
  import { createClient } from "@supabase/supabase-js";

  const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
  const { data: { session } } = await supabase.auth.getSession();
  if (!session) location.href = "/cms/login";
  document.querySelector('[data-logout]')?.addEventListener('click', async (event) => {
    event.preventDefault();
    await supabase.auth.signOut();
    location.href = "/cms/login";
  });
</script>

<style>
  .shell { min-height: 100vh; display: grid; grid-template-columns: 280px minmax(0, 1fr); background: #232323; color: #f8f6f3; }
  .sidebar { min-height: 100vh; background: #181818; border-right: 1px solid #5c5c5c; display: flex; flex-direction: column; padding: 34px 0 25px; position: sticky; top: 0; height: 100vh; }
  .brand { color: #f6f3ef; text-decoration: none; font-size: 19px; line-height: 1; font-weight: 900; letter-spacing: -1px; padding: 0 31px; margin-bottom: 110px; }
  .brand span { color: #e0ed65; }
  nav { display: grid; }
  nav a { color: #f7f5f2; font-size: 17px; font-weight: 800; text-transform: uppercase; text-decoration: none; padding: 13px 31px; }
  nav a:hover, nav a.active { background: #2b2b2b; }
  .logout { margin: auto 30px 0; background: #e0ed65; color: #121212; text-align: center; text-decoration: none; text-transform: uppercase; font-weight: 900; border-radius: 14px; padding: 12px; }
  .main { min-width: 0; padding: 30px; }
  @media (max-width: 780px) { .shell { display:block; } .sidebar { position: static; height:auto; min-height:0; padding: 18px 0; } .brand { margin-bottom: 20px; } nav { display:flex; overflow:auto; } nav a { white-space: nowrap; padding: 10px 15px; font-size: 13px; } .logout { display:none; } .main { padding: 22px 16px; } }
</style>
